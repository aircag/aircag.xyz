---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found">
  <div class="py-20 flex flex-col items-center text-center">
    <p class="font-mono text-[#22d3ee] text-7xl font-bold mb-2 select-none">404</p>
    <p class="font-mono text-slate-400 text-sm mb-1">page not found</p>
    <p class="font-mono text-slate-500 text-xs mb-8">
      no need to brute force — it's open source.
    </p>
    <a
      href="https://github.com/aircag/aircag.xyz"
      target="_blank"
      rel="noopener noreferrer"
      class="font-mono text-xs text-[#22d3ee] border border-[#22d3ee]/30 px-4 py-2 rounded hover:bg-[#22d3ee]/10 transition-colors"
    >
      github.com/aircag/aircag.xyz
    </a>
    <a
      href="/"
      class="mt-8 font-mono text-xs text-slate-500 hover:text-slate-300 transition-colors"
    >
      ← go home
    </a>
  </div>
</BaseLayout>
