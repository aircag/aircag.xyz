---
const navLinks = [
  { href: '/blog', label: 'blog' },
  { href: '/about', label: 'about' },
];

const currentPath = Astro.url.pathname;
---

<header class="w-full border-b border-[#1e293b]">
  <nav class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/aircag.png"
        alt="aircag"
        class="w-7 h-7 rounded-full object-cover ring-1 ring-[#1e293b] group-hover:ring-[#22d3ee] transition-all"
      />
      <span class="font-mono text-[#22d3ee] group-hover:text-white transition-colors text-sm font-medium">
        aircag.xyz
      </span>
    </a>
    <ul class="flex items-center gap-6">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'font-mono text-sm transition-colors',
                currentPath === href || currentPath.startsWith(href + '/')
                  ? 'text-[#22d3ee]'
                  : 'text-slate-400 hover:text-slate-200',
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
